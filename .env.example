# Platform Core
PORT=8090

# Postgres (наша БД)
DB_HOST=localhost
DB_PORT=5440
DB_USER=platform
DB_PASSWORD=platform
DB_NAME=platform

# Redis
REDIS_HOST=localhost
REDIS_PORT=6390

# Ory Hydra
HYDRA_ADMIN_URL=http://localhost:4445
HYDRA_PUBLIC_URL=http://localhost:4444
HYDRA_TOKEN_URL=http://localhost:4444
TRUSTED_CLIENT_IDS=papyrus

# Hub OIDC client
HUB_CLIENT_ID=hub
HUB_CLIENT_SECRET=hub-secret
SELF_URL=http://localhost:8090

# Base URL for links in emails
BASE_URL=http://localhost:8090

# Mail: "log" (dev, prints link) or "smtp"
MAIL_MODE=log
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@papyrus.local
